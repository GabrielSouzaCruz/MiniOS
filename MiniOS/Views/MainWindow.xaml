<Window x:Class="MiniOS.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MiniOS - Painel de Controle" Height="650" Width="1000"
        Background="#2D2D30" WindowStartupLocation="CenterScreen"
        Icon="/Images/logo.png">

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,15,0">

            <Image Source="pack://application:,,,/Images/logo.png" Width="100" Height="100" Margin="0,0,0,15" HorizontalAlignment="Center" Stretch="Uniform"/>

            <GroupBox Header="Gestão de Processos (CPU)" Foreground="White" BorderBrush="#007ACC" Margin="0,0,0,15" Padding="10">
                <StackPanel>
                    <TextBox x:Name="txtProcessName" Margin="0,0,0,10" Padding="5" Text="Processo A" Foreground="Gray" GotFocus="RemoveText_GotFocus"/>
                    <TextBox x:Name="txtProcessTime" Margin="0,0,0,10" Padding="5" Text="10" Foreground="Gray" GotFocus="RemoveText_GotFocus"/>

                    <Button Content="Criar Processo" Click="BtnCreateProcess_Click" Padding="5" Margin="0,0,0,10" Background="#3E3E42" Foreground="White"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="btnRunScheduler" Grid.Column="0" Content="Executar (Manual)" Click="BtnRunScheduler_Click" Padding="5" Margin="0,0,5,10" Background="#007ACC" Foreground="White" FontWeight="Bold" IsEnabled="False"/>
                        <Button x:Name="btnToggleClock" Grid.Column="1" Content="Ligar Clock (Auto)" Click="BtnToggleClock_Click" Padding="5" Margin="5,0,0,10" Background="#28A745" Foreground="White" FontWeight="Bold"/>
                    </Grid>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Gestão de Memória (RAM)" Foreground="White" BorderBrush="#007ACC" Margin="0,0,0,15" Padding="10">
                <StackPanel>
                    <TextBlock x:Name="lblMemoryStatus" Text="Uso da RAM: 0 MB / 1024 MB" Foreground="White" Margin="0,0,0,5" FontWeight="Bold"/>
                    <ProgressBar x:Name="pbRamUsage" Height="20" Margin="0,0,0,10" Minimum="0" Maximum="1024" Value="0" Foreground="LimeGreen" Background="#3E3E42" BorderThickness="0"/>

                    <TextBox x:Name="txtMemSize" Margin="0,0,0,10" Padding="5" Text="Tamanho em MB (ex: 200)" Foreground="Gray" GotFocus="RemoveText_GotFocus"/>
                    <Button Content="Alocar Memória" Click="BtnAllocateMemory_Click" Padding="5" Margin="0,0,0,10" Background="#3E3E42" Foreground="White"/>

                    <TextBox x:Name="txtMemId" Margin="0,0,0,10" Padding="5" Text="ID do Bloco a Libertar" Foreground="Gray" GotFocus="RemoveText_GotFocus"/>
                    <Button Content="Libertar Memória" Click="BtnFreeMemory_Click" Padding="5" Margin="0,0,0,10" Background="#3E3E42" Foreground="White"/>
                    <Button Content="Ver Estado da RAM" Click="BtnStatusRAM_Click" Padding="5" Background="#007ACC" Foreground="White" FontWeight="Bold"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Sistema de Ficheiros (Disco)" Foreground="White" BorderBrush="#007ACC" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBox x:Name="txtDirectory" Margin="0,0,0,10" Padding="5" Text="Root" Foreground="Gray" GotFocus="RemoveText_GotFocus"/>

                        <TextBox x:Name="txtFileName" Margin="0,0,0,10" Padding="5" Text="Nome do Ficheiro" Foreground="Gray" GotFocus="RemoveText_GotFocus"/>
                        <TextBox x:Name="txtFileContent" Margin="0,0,0,10" Padding="5" Text="Conteúdo..." Foreground="Gray" GotFocus="RemoveText_GotFocus"/>

                        <Button Content="Criar Ficheiro" Click="BtnCreateFile_Click" Padding="5" Margin="0,0,0,10" Background="#3E3E42" Foreground="White"/>
                        <Button Content="Ler Ficheiro" Click="BtnReadFile_Click" Padding="5" Margin="0,0,0,10" Background="#007ACC" Foreground="White" FontWeight="Bold"/>
                        <Button Content="Apagar Ficheiro" Click="BtnDeleteFile_Click" Padding="5" Margin="0,0,0,10" Background="#B22222" Foreground="White" FontWeight="Bold"/>
                    </StackPanel>

                    <DataGrid x:Name="gridFiles" Grid.Row="1" AutoGenerateColumns="True" IsReadOnly="True" 
                              Background="#1E1E1E" Foreground="Black" RowBackground="White" 
                              AlternatingRowBackground="#E0E0E0" HeadersVisibility="Column" MinHeight="100"/>
                </Grid>
            </GroupBox>

        </StackPanel>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <GroupBox Grid.Row="0" Header="Gestor de Tarefas (Fila de Prontos)" Foreground="White" BorderBrush="#007ACC" Margin="0,0,0,10">
                <DataGrid x:Name="gridProcesses" AutoGenerateColumns="True" IsReadOnly="True" 
                          Background="#1E1E1E" Foreground="Black" RowBackground="White" 
                          AlternatingRowBackground="#E0E0E0" HeadersVisibility="Column"/>
            </GroupBox>

            <GroupBox Grid.Row="1" Header="Terminal do Sistema" Foreground="White" BorderBrush="#007ACC">
                <TextBox x:Name="txtTerminal" Background="#1E1E1E" Foreground="#00FF00" 
                         FontFamily="Consolas" FontSize="14" IsReadOnly="True" 
                         TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Padding="10"/>
            </GroupBox>
        </Grid>
    </Grid>
</Window>